generator client {  provider = "prisma-client-js"} datasource db {  provider = "postgresql"  url      = env("DATABASE_URL")} // ============================================================================// 1. AUTH — NextAuth.js adapter tables + User// ============================================================================// ASSUMPTION (confirmed with you): full NextAuth Prisma-adapter schema// (Account/Session/VerificationToken), even though the docs only mention// email/password as the concrete method today — this keeps the door open// for OAuth providers later with zero migration. model User {  id            String    @id @default(cuid())  name          String?  email         String?   @unique  emailVerified DateTime?  image         String?  passwordHash  String? // null if the user only ever uses an OAuth provider  createdAt     DateTime  @default(now())  updatedAt     DateTime  @updatedAt   // Per-user preference (not per-shop) — language toggle persists per user (4.15)  preferredLanguage String @default("en") // "en" | "hi"   accounts      Account[]  sessions      Session[]  shopMembers   ShopMember[]   // Reverse relations for "who did this" audit-style fields across the app  transactionsCreated   Transaction[]      @relation("TransactionCreatedBy")  transactionsDeleted   Transaction[]      @relation("TransactionDeletedBy")  transactionAudits     TransactionAudit[] @relation("TransactionAuditChangedBy")  contactsDeleted       Contact[]          @relation("ContactDeletedBy")  attendanceMarkedBy    Attendance[]       @relation("AttendanceMarkedBy")  salaryPaymentsPaidBy  SalaryPayment[]    @relation("SalaryPaymentPaidBy")  salaryAudits          SalaryAudit[]      @relation("SalaryAuditChangedBy")  stockEntriesRecorded  StockEntry[]       @relation("StockEntryRecordedBy")  stockEntriesReviewed  StockEntry[]       @relation("StockEntryReviewedBy")  lossesRecorded        Loss[]             @relation("LossRecordedBy")  paperImportsUploaded  PaperImportBatch[] @relation("PaperImportUploadedBy")  paperImportPagesReviewed PaperImportPage[] @relation("PaperImportPageReviewedBy")  attachmentsUploaded   Attachment[]       @relation("AttachmentUploadedBy")  notifications         Notification[]  productsDeleted       Product[]          @relation("ProductDeletedBy")  workersDeleted        Worker[]           @relation("WorkerDeletedBy")   @@index([email])} // Standard NextAuth adapter model — links a User to an OAuth/credentials provider accountmodel Account {  id                String  @id @default(cuid())  userId            String  type              String  provider          String  providerAccountId String  refresh_token     String? @db.Text  access_token      String? @db.Text  expires_at        Int?  token_type        String?  scope             String?  id_token          String? @db.Text  session_state     String?   user User @relation(fields: [userId], references: [id], onDelete: Cascade)   @@unique([provider, providerAccountId])  @@index([userId])} // Standard NextAuth adapter model — one row per active login session (JWT or DB strategy)model Session {  id           String   @id @default(cuid())  sessionToken String   @unique  userId       String  expires      DateTime   user User @relation(fields: [userId], references: [id], onDelete: Cascade)   @@index([userId])} // Standard NextAuth adapter model — email verification / passwordless login tokensmodel VerificationToken {  identifier String  token      String   @unique  expires    DateTime   @@unique([identifier, token])} // ============================================================================// 2. SHOP & MEMBERSHIP// ============================================================================ enum Role {  OWNER  STAFF} model Shop {  id        String   @id @default(cuid())  name      String  logoUrl   String?  createdAt DateTime @default(now())  updatedAt DateTime @updatedAt   // Per-shop settings (Section 4, Final Decisions on Remaining Open Items)  defaultLanguage   String  @default("en") // "en" | "hi" — shop-wide default; user can override (4.15)  halfDayFraction   Decimal @default(0.5) @db.Decimal(3, 2) // e.g. 0.50 = 50% of daily wage  expiryAlertDays   Int     @default(3)   // Staff permission overrides — the docs describe these as configurable  // toggles set by the Owner in Settings (4.15 / permissions matrix), not a  // fixed rule, so they are modeled as explicit booleans rather than a JSON  // blob for type-safety and easy querying.  staffCanEditTransactions   Boolean @default(true)  // "own entries" by default per matrix  staffCanDeleteTransactions Boolean @default(false)  staffCanViewFinancials     Boolean @default(true)  staffCanRestoreTrash       Boolean @default(false)   members            ShopMember[]  contacts           Contact[]  transactions       Transaction[]  earningsRollups    EarningsRollup[]  notifications      Notification[]  workers            Worker[]  products           Product[]  losses             Loss[]  paperImportBatches PaperImportBatch[]   @@index([name])} // Join table: a User can belong to multiple Shops, and a Shop has multiple// Users — this is the multi-shop / multi-staff model (1.4, 4.9b).model ShopMember {  id       String   @id @default(cuid())  userId   String  shopId   String  role     Role  joinedAt DateTime @default(now())   user User @relation(fields: [userId], references: [id], onDelete: Cascade)  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)   @@unique([userId, shopId]) // a user has exactly one role per shop  @@index([shopId])  @@index([userId])} // ============================================================================// 3. CONTACTS & TRANSACTIONS (core ledger)// ============================================================================ enum TransactionType {  YOU_GAVE // increases what the contact owes the shop  YOU_GOT  // decreases what the contact owes the shop} model Contact {  id      String  @id @default(cuid())  shopId  String  name    String  phone   String?  email   String?   // Running balance: positive = contact owes shop (due), negative = shop  // owes contact (payable). Maintained via row-locked updates (1.7).  balance Decimal @default(0) @db.Decimal(14, 2)   dueDate DateTime? // optional expected-payment date (reminders)   // Set on creation from either manual entry or bulk import/paper migration.  // openingBalanceAsOf lets a migrated balance be dated in the past so the  // earnings rollup doesn't miscount old money as "today's" activity (3.3).  openingBalance      Decimal   @default(0) @db.Decimal(14, 2)  openingBalanceAsOf  DateTime?   // Soft delete — ASSUMPTION (per your direction): extended to Contact for  // consistency with Transaction, though the docs only state this  // explicitly for Transaction.  isDeleted Boolean   @default(false)  deletedAt DateTime?  deletedBy String?   createdAt DateTime @default(now())  updatedAt DateTime @updatedAt   shop             Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)  deletedByUser    User?               @relation("ContactDeletedBy", fields: [deletedBy], references: [id])  transactions     Transaction[]  attachments      Attachment[]  paperImportPages PaperImportPage[]   @@index([shopId])  @@index([shopId, isDeleted])  @@index([phone])  @@index([email])  @@index([shopId, dueDate])} model Transaction {  id     String          @id @default(cuid())  shopId String  contactId String  type   TransactionType  amount Decimal         @db.Decimal(14, 2)  note   String?   // Cached snapshot of the contact's running balance right after this  // transaction, so paginated history never needs to recompute a running  // total (1.8).  balanceAfter Decimal @db.Decimal(14, 2)   // Hybrid concurrency control (1.1)  version   Int       @default(1)  lockedBy  String?   // userId currently holding the soft-lock, if any  lockedAt  DateTime? // lock acquired/heartbeat timestamp; TTL enforced in app logic (~2 min)   // Soft delete (1.5) — required for both audit trail and Trash/Restore  isDeleted Boolean   @default(false)  deletedAt DateTime?  deletedBy String?   createdBy String  createdAt DateTime @default(now())  updatedAt DateTime @updatedAt   shop          Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)  contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)  createdByUser User               @relation("TransactionCreatedBy", fields: [createdBy], references: [id])  deletedByUser User?              @relation("TransactionDeletedBy", fields: [deletedBy], references: [id])  audits        TransactionAudit[]  attachments   Attachment[]   // Cursor pagination is keyed on (createdAt, id) per 1.8  @@index([contactId, createdAt, id])  @@index([shopId, createdAt])  @@index([shopId, isDeleted])  @@index([contactId, isDeleted])} // Full old/new snapshot on every change — written in the SAME db transaction// as the change itself so audit trail and data can never drift apart (1.5, MVP list).model TransactionAudit {  id            String   @id @default(cuid())  transactionId String  changedBy     String  changedAt     DateTime @default(now())  action        String   // "CREATE" | "UPDATE" | "DELETE" | "RESTORE"  oldValue      Json?    // full row snapshot before the change (null on CREATE)  newValue      Json?    // full row snapshot after the change (null on DELETE)   transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)  changedByUser   User        @relation("TransactionAuditChangedBy", fields: [changedBy], references: [id])   @@index([transactionId, changedAt])} // Daily rollup, updated atomically alongside every write that affects it (1.9).// Monthly totals are derived by summing daily rows for the month, not stored separately.model EarningsRollup {  id          String   @id @default(cuid())  shopId      String  date        DateTime @db.Date  totalEarned Decimal  @default(0) @db.Decimal(14, 2)  totalLoss   Decimal  @default(0) @db.Decimal(14, 2)   shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)   @@unique([shopId, date]) // one row per shop per day — primary dashboard read path  @@index([shopId, date])} // ============================================================================// 4. ATTACHMENTS (polymorphic — receipts, paper-khata page images, etc.)// ============================================================================// Modeled as its own table per your direction, reusable across Transaction,// Contact, and PaperImportPage rather than a URL column duplicated on each. enum AttachmentEntityType {  TRANSACTION  CONTACT  PAPER_IMPORT_PAGE} model Attachment {  id         String               @id @default(cuid())  entityType AttachmentEntityType  entityId   String               // polymorphic FK — enforced in application code, not a DB constraint  url        String               // GCS bucket URL  mimeType   String?  uploadedBy String  createdAt  DateTime             @default(now())   uploadedByUser User    @relation("AttachmentUploadedBy", fields: [uploadedBy], references: [id])   // Optional direct relations for query convenience — nullable, only one is  // ever populated depending on entityType. This trades a little redundancy  // for the ability to use Prisma's native relation `include` instead of a  // manual two-step lookup by entityType/entityId.  transactionId String?  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)  contactId     String?  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)  paperImportPageId String?  paperImportPage    PaperImportPage? @relation(fields: [paperImportPageId], references: [id], onDelete: Cascade)   @@index([entityType, entityId])} // ============================================================================// 5. NOTIFICATIONS// ============================================================================ enum NotificationChannel {  IN_APP  PUSH  SMS      // schema-ready, not implemented in v1 (deferred, out of scope)  WHATSAPP // schema-ready, not implemented in v1 (deferred, out of scope)} enum NotificationType {  DUE_REMINDER  TRANSACTION_EDITED  TRANSACTION_DELETED  STOCK_APPROVAL_REQUESTED  STOCK_APPROVAL_DECIDED  EXPIRY_ALERT  PAPER_IMPORT_READY  SALARY_PAYMENT_RECORDED} model Notification {  id        String              @id @default(cuid())  shopId    String  userId    String              // recipient  type      NotificationType  channel   NotificationChannel @default(IN_APP)  title     String  body      String  isRead    Boolean             @default(false)  linkUrl   String?             // deep-link target, e.g. into a contact's ledger  createdAt DateTime            @default(now())   shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)  user User @relation(fields: [userId], references: [id], onDelete: Cascade)   @@index([userId, isRead, createdAt])  @@index([shopId])} // ============================================================================// 6. WORKER & SALARY MANAGEMENT (extended module)// ============================================================================ enum PayType {  MONTHLY  DAILY_WAGE} enum AttendanceStatus {  PRESENT  ABSENT  HALF_DAY  LEAVE} enum SalaryStatus {  PENDING  PAID} model Worker {  id             String   @id @default(cuid())  shopId         String  name           String  designation    String?  payType        PayType  monthlySalary  Decimal? @db.Decimal(14, 2) // set when payType = MONTHLY  dailyWageRate  Decimal? @db.Decimal(14, 2) // set when payType = DAILY_WAGE  joiningDate    DateTime  active         Boolean  @default(true)   // Soft delete — ASSUMPTION (per your direction), extended for consistency  isDeleted Boolean   @default(false)  deletedAt DateTime?  deletedBy String?   createdAt DateTime @default(now())  updatedAt DateTime @updatedAt   shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)  deletedByUser   User?           @relation("WorkerDeletedBy", fields: [deletedBy], references: [id])  attendanceLogs  Attendance[]  salaryPayments  SalaryPayment[]   @@index([shopId])  @@index([shopId, isDeleted])} // One row per worker per daymodel Attendance {  id       String           @id @default(cuid())  workerId String  date     DateTime         @db.Date  status   AttendanceStatus  markedBy String  markedAt DateTime         @default(now())   worker       Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)  markedByUser User   @relation("AttendanceMarkedBy", fields: [markedBy], references: [id])   @@unique([workerId, date]) // exactly one attendance record per worker per day  @@index([workerId, date])} model SalaryPayment {  id          String       @id @default(cuid())  workerId    String  amount      Decimal      @db.Decimal(14, 2)  periodStart DateTime     @db.Date  periodEnd   DateTime     @db.Date  paidOn      DateTime?  status      SalaryStatus @default(PENDING)  note        String?   // Same hybrid concurrency pattern as Transaction (1.1), applied here too  version  Int       @default(1)  lockedBy String?  lockedAt DateTime?   paidBy    String?  createdAt DateTime @default(now())  updatedAt DateTime @updatedAt   worker      Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)  paidByUser  User?         @relation("SalaryPaymentPaidBy", fields: [paidBy], references: [id])  audits      SalaryAudit[]   @@index([workerId, periodStart])} model SalaryAudit {  id              String   @id @default(cuid())  salaryPaymentId String  changedBy       String  changedAt       DateTime @default(now())  action          String   // "CREATE" | "UPDATE" | "DELETE" | "APPROVE" | "REJECT"  oldValue        Json?  newValue        Json?   salaryPayment  SalaryPayment @relation(fields: [salaryPaymentId], references: [id], onDelete: Cascade)  changedByUser  User          @relation("SalaryAuditChangedBy", fields: [changedBy], references: [id])   @@index([salaryPaymentId, changedAt])} // ============================================================================// 7. INVENTORY & LOSS TRACKING (extended module)// ============================================================================ enum StockEntryType {  PURCHASE  SALE  ADJUSTMENT  LOSS} enum StockEntryStatus {  PENDING  APPROVED  REJECTED} enum LossReason {  EXPIRED  DAMAGED  OTHER} model Product {  id            String   @id @default(cuid())  shopId        String  name          String  sku           String?  category      String?  unit          String   // e.g. "kg", "pcs", "litre" — free text per docs (no enum specified)  purchasePrice Decimal  @db.Decimal(14, 2)  sellingPrice  Decimal  @db.Decimal(14, 2)  reorderLevel  Int?   // Cached running total, updated only on StockEntry approval, using the  // same row-locked pattern as Contact.balance (1.7 / 3.2).  currentStock  Decimal  @default(0) @db.Decimal(14, 2)   // Soft delete — ASSUMPTION (per your direction), extended for consistency  isDeleted Boolean   @default(false)  deletedAt DateTime?  deletedBy String?   createdAt DateTime @default(now())  updatedAt DateTime @updatedAt   shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)  deletedByUser User?          @relation("ProductDeletedBy", fields: [deletedBy], references: [id])  batches       ProductBatch[]  stockEntries  StockEntry[]  losses        Loss[]   @@index([shopId])  @@index([shopId, isDeleted])  @@index([sku])} model ProductBatch {  id            String    @id @default(cuid())  productId     String  batchNumber   String  quantity      Decimal   @db.Decimal(14, 2)  expiryDate    DateTime? @db.Date  purchaseDate  DateTime  @db.Date  purchasePrice Decimal   @db.Decimal(14, 2)   createdAt DateTime @default(now())   product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)  stockEntries StockEntry[]  losses       Loss[]   @@index([productId])  @@index([productId, expiryDate]) // supports the daily expiry-check cron job} model StockEntry {  id         String            @id @default(cuid())  productId  String  batchId    String?  type       StockEntryType  quantity   Decimal           @db.Decimal(14, 2)  pricePerUnit Decimal?        @db.Decimal(14, 2)  note       String?   // Approval workflow (Section 4, Final Decisions): PURCHASE/SALE  // auto-approve; ADJUSTMENT/LOSS start PENDING and require Owner approval.  status     StockEntryStatus  @default(PENDING)  reviewedBy String?  reviewedAt DateTime?  reviewNote String?   recordedBy String  createdAt  DateTime @default(now())  updatedAt  DateTime @updatedAt   product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)  batch          ProductBatch? @relation(fields: [batchId], references: [id])  recordedByUser User         @relation("StockEntryRecordedBy", fields: [recordedBy], references: [id])  reviewedByUser User?        @relation("StockEntryReviewedBy", fields: [reviewedBy], references: [id])   @@index([productId, createdAt])  @@index([status])} model Loss {  id         String     @id @default(cuid())  shopId     String  productId  String  batchId    String?  quantity   Decimal    @db.Decimal(14, 2)  reason     LossReason  lossValue  Decimal    @db.Decimal(14, 2) // quantity × purchasePrice  recordedBy String  createdAt  DateTime   @default(now())   shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)  batch          ProductBatch? @relation(fields: [batchId], references: [id])  recordedByUser User          @relation("LossRecordedBy", fields: [recordedBy], references: [id])   @@index([shopId, createdAt])  @@index([productId])} // ============================================================================// 8. AI-ASSISTED PAPER KHATA MIGRATION (extended module)// ============================================================================ enum PaperImportBatchStatus {  PENDING  PROCESSING  READY_FOR_REVIEW  COMMITTED  CANCELLED} enum PaperImportPageStatus {  PENDING  EXTRACTED  FAILED  REVIEWED} model PaperImportBatch {  id         String                 @id @default(cuid())  shopId     String  uploadedBy String  asOfDate   DateTime               @db.Date // single date the whole batch represents  status     PaperImportBatchStatus @default(PENDING)  createdAt  DateTime               @default(now())  updatedAt  DateTime               @updatedAt   shop           Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)  uploadedByUser User              @relation("PaperImportUploadedBy", fields: [uploadedBy], references: [id])  pages          PaperImportPage[]   @@index([shopId, status])} model PaperImportPage {  id                 String                 @id @default(cuid())  batchId            String  imageUrl           String                 // GCS URL — also mirrored as an Attachment row for reuse  status             PaperImportPageStatus  @default(PENDING)  rawExtractedJson   Json?                  // AI structured output: name, balance/entries, per-field confidence  confidenceScore    Decimal?               @db.Decimal(4, 3) // 0.000–1.000  resultingContactId String?                // nullable until reviewed/committed  reviewedBy         String?  reviewedAt         DateTime?   batch             PaperImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)  resultingContact  Contact?         @relation(fields: [resultingContactId], references: [id])  reviewedByUser    User?            @relation("PaperImportPageReviewedBy", fields: [reviewedBy], references: [id])  attachments       Attachment[]   @@index([batchId, status])}