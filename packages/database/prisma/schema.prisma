generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// 1. AUTH — NextAuth.js adapter tables + User
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  preferredLanguage String @default("en")

  accounts      Account[]
  sessions      Session[]
  shopMembers   ShopMember[]

  transactionsCreated   Transaction[]      @relation("TransactionCreatedBy")
  transactionsDeleted   Transaction[]      @relation("TransactionDeletedBy")
  transactionAudits     TransactionAudit[] @relation("TransactionAuditChangedBy")
  contactsDeleted       Contact[]          @relation("ContactDeletedBy")
  attendanceMarkedBy    Attendance[]       @relation("AttendanceMarkedBy")
  salaryPaymentsPaidBy  SalaryPayment[]    @relation("SalaryPaymentPaidBy")
  salaryAudits          SalaryAudit[]      @relation("SalaryAuditChangedBy")
  stockEntriesRecorded  StockEntry[]       @relation("StockEntryRecordedBy")
  stockEntriesReviewed  StockEntry[]       @relation("StockEntryReviewedBy")
  lossesRecorded        Loss[]             @relation("LossRecordedBy")
  paperImportsUploaded  PaperImportBatch[] @relation("PaperImportUploadedBy")
  paperImportPagesReviewed PaperImportPage[] @relation("PaperImportPageReviewedBy")
  attachmentsUploaded   Attachment[]       @relation("AttachmentUploadedBy")
  notifications         Notification[]
  productsDeleted       Product[]          @relation("ProductDeletedBy")
  workersDeleted        Worker[]           @relation("WorkerDeletedBy")

  contactsCreated       Contact[]          @relation("ContactCreatedBy")
  productsCreated       Product[]          @relation("ProductCreatedBy")
  workersCreated        Worker[]           @relation("WorkerCreatedBy")
  shopsCreated          Shop[]             @relation("ShopCreatedBy")

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// 2. SHOP & MEMBERSHIP
// ============================================================================

enum Role {
  OWNER
  STAFF
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultLanguage   String  @default("en")
  halfDayFraction   Decimal @default(0.5) @db.Decimal(3, 2)
  expiryAlertDays   Int     @default(3)

  staffCanEditTransactions   Boolean @default(true)
  staffCanDeleteTransactions Boolean @default(false)
  staffCanViewFinancials     Boolean @default(true)
  staffCanRestoreTrash       Boolean @default(false)

  members            ShopMember[]
  contacts           Contact[]
  transactions       Transaction[]
  earningsRollups    EarningsRollup[]
  notifications      Notification[]
  workers            Worker[]
  products           Product[]
  losses             Loss[]
  paperImportBatches PaperImportBatch[]

  createdBy     String?
  createdByUser User?   @relation("ShopCreatedBy", fields: [createdBy], references: [id])

  @@index([name])
}

model ShopMember {
  id       String   @id @default(cuid())
  userId   String
  shopId   String
  role     Role
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId])
  @@index([userId])
}

// ============================================================================
// 3. CONTACTS & TRANSACTIONS
// ============================================================================

enum TransactionType {
  YOU_GAVE
  YOU_GOT
}

model Contact {
  id      String  @id @default(cuid())
  shopId  String
  name    String
  phone   String?
  email   String?

  balance Decimal @default(0) @db.Decimal(14, 2)
  dueDate DateTime?

  openingBalance      Decimal   @default(0) @db.Decimal(14, 2)
  openingBalanceAsOf  DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop             Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  deletedByUser    User?               @relation("ContactDeletedBy", fields: [deletedBy], references: [id])
  transactions     Transaction[]
  attachments      Attachment[]
  paperImportPages PaperImportPage[]

  createdBy        String?
  createdByUser    User?               @relation("ContactCreatedBy", fields: [createdBy], references: [id])

  @@index([shopId])
  @@index([shopId, isDeleted])
  @@index([phone])
  @@index([email])
  @@index([shopId, dueDate])
}

model Transaction {
  id        String          @id @default(cuid())
  shopId    String
  contactId String
  type      TransactionType
  amount    Decimal         @db.Decimal(14, 2)
  note      String?

  balanceAfter Decimal @db.Decimal(14, 2)

  version   Int       @default(1)
  lockedBy  String?
  lockedAt  DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop          Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdByUser User               @relation("TransactionCreatedBy", fields: [createdBy], references: [id])
  deletedByUser User?              @relation("TransactionDeletedBy", fields: [deletedBy], references: [id])
  audits        TransactionAudit[]
  attachments   Attachment[]

  @@index([contactId, createdAt, id])
  @@index([shopId, createdAt])
  @@index([shopId, isDeleted])
  @@index([contactId, isDeleted])
}

model TransactionAudit {
  id            String   @id @default(cuid())
  transactionId String
  changedBy     String
  changedAt     DateTime @default(now())
  action        String
  oldValue      Json?
  newValue      Json?

  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  changedByUser   User        @relation("TransactionAuditChangedBy", fields: [changedBy], references: [id])

  @@index([transactionId, changedAt])
}

model EarningsRollup {
  id          String   @id @default(cuid())
  shopId      String
  date        DateTime @db.Date
  totalEarned Decimal  @default(0) @db.Decimal(14, 2)
  totalLoss   Decimal  @default(0) @db.Decimal(14, 2)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
  @@index([shopId, date])
}

// ============================================================================
// 4. ATTACHMENTS
// ============================================================================

enum AttachmentEntityType {
  TRANSACTION
  CONTACT
  PAPER_IMPORT_PAGE
}

model Attachment {
  id         String               @id @default(cuid())
  entityType AttachmentEntityType
  entityId   String
  url        String
  mimeType   String?
  uploadedBy String
  createdAt  DateTime             @default(now())

  uploadedByUser User    @relation("AttachmentUploadedBy", fields: [uploadedBy], references: [id])

  transactionId     String?
  transaction       Transaction?     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact?         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  paperImportPageId String?
  paperImportPage   PaperImportPage? @relation(fields: [paperImportPageId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
}

// ============================================================================
// 5. NOTIFICATIONS
// ============================================================================

enum NotificationChannel {
  IN_APP
  PUSH
  SMS
  WHATSAPP
}

enum NotificationType {
  DUE_REMINDER
  TRANSACTION_EDITED
  TRANSACTION_DELETED
  STOCK_APPROVAL_REQUESTED
  STOCK_APPROVAL_DECIDED
  EXPIRY_ALERT
  PAPER_IMPORT_READY
  SALARY_PAYMENT_RECORDED
}

model Notification {
  id        String              @id @default(cuid())
  shopId    String
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  isRead    Boolean             @default(false)
  linkUrl   String?
  createdAt DateTime            @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([shopId])
}

// ============================================================================
// 6. WORKER & SALARY MANAGEMENT
// ============================================================================

enum PayType {
  MONTHLY
  DAILY_WAGE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum SalaryStatus {
  PENDING
  PAID
}

model Worker {
  id             String   @id @default(cuid())
  shopId         String
  name           String
  designation    String?
  payType        PayType
  monthlySalary  Decimal? @db.Decimal(14, 2)
  dailyWageRate  Decimal? @db.Decimal(14, 2)
  joiningDate    DateTime
  active         Boolean  @default(true)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  deletedByUser   User?           @relation("WorkerDeletedBy", fields: [deletedBy], references: [id])
  attendanceLogs  Attendance[]
  salaryPayments  SalaryPayment[]

  createdBy       String?
  createdByUser   User?           @relation("WorkerCreatedBy", fields: [createdBy], references: [id])

  @@index([shopId])
  @@index([shopId, isDeleted])
}

model Attendance {
  id       String           @id @default(cuid())
  workerId String
  date     DateTime         @db.Date
  status   AttendanceStatus
  markedBy String
  markedAt DateTime         @default(now())

  worker       Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  markedByUser User   @relation("AttendanceMarkedBy", fields: [markedBy], references: [id])

  @@unique([workerId, date])
  @@index([workerId, date])
}

model SalaryPayment {
  id          String       @id @default(cuid())
  workerId    String
  amount      Decimal      @db.Decimal(14, 2)
  periodStart DateTime     @db.Date
  periodEnd   DateTime     @db.Date
  paidOn      DateTime?
  status      SalaryStatus @default(PENDING)
  note        String?

  version  Int       @default(1)
  lockedBy String?
  lockedAt DateTime?

  paidBy    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worker      Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  paidByUser  User?         @relation("SalaryPaymentPaidBy", fields: [paidBy], references: [id])
  audits      SalaryAudit[]

  @@index([workerId, periodStart])
}

model SalaryAudit {
  id              String   @id @default(cuid())
  salaryPaymentId String
  changedBy       String
  changedAt       DateTime @default(now())
  action          String
  oldValue        Json?
  newValue        Json?

  salaryPayment  SalaryPayment @relation(fields: [salaryPaymentId], references: [id], onDelete: Cascade)
  changedByUser  User          @relation("SalaryAuditChangedBy", fields: [changedBy], references: [id])

  @@index([salaryPaymentId, changedAt])
}

// ============================================================================
// 7. INVENTORY & LOSS TRACKING
// ============================================================================

enum StockEntryType {
  PURCHASE
  SALE
  ADJUSTMENT
  LOSS
}

enum StockEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LossReason {
  EXPIRED
  DAMAGED
  OTHER
}

model Product {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  sku           String?
  category      String?
  unit          String
  purchasePrice Decimal  @db.Decimal(14, 2)
  sellingPrice  Decimal  @db.Decimal(14, 2)
  reorderLevel  Int?

  currentStock  Decimal  @default(0) @db.Decimal(14, 2)
  expiryDate    DateTime? @db.Date

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  deletedByUser User?          @relation("ProductDeletedBy", fields: [deletedBy], references: [id])
  batches       ProductBatch[]
  stockEntries  StockEntry[]
  losses        Loss[]

  createdBy     String?
  createdByUser User?          @relation("ProductCreatedBy", fields: [createdBy], references: [id])

  @@index([shopId])
  @@index([shopId, isDeleted])
  @@index([sku])
}

model ProductBatch {
  id            String    @id @default(cuid())
  productId     String
  batchNumber   String
  quantity      Decimal   @db.Decimal(14, 2)
  expiryDate    DateTime? @db.Date
  purchaseDate  DateTime  @db.Date
  purchasePrice Decimal   @db.Decimal(14, 2)

  createdAt DateTime @default(now())

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockEntries StockEntry[]
  losses       Loss[]

  @@index([productId])
  @@index([productId, expiryDate])
}

model StockEntry {
  id           String            @id @default(cuid())
  productId    String
  batchId      String?
  type         StockEntryType
  quantity     Decimal           @db.Decimal(14, 2)
  pricePerUnit Decimal?          @db.Decimal(14, 2)
  note         String?

  status     StockEntryStatus  @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  reviewNote String?

  recordedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch          ProductBatch? @relation(fields: [batchId], references: [id])
  recordedByUser User          @relation("StockEntryRecordedBy", fields: [recordedBy], references: [id])
  reviewedByUser User?         @relation("StockEntryReviewedBy", fields: [reviewedBy], references: [id])

  @@index([productId, createdAt])
  @@index([status])
}

model Loss {
  id         String     @id @default(cuid())
  shopId     String
  productId  String
  batchId    String?
  quantity   Decimal    @db.Decimal(14, 2)
  reason     LossReason
  lossValue  Decimal    @db.Decimal(14, 2)
  recordedBy String
  createdAt  DateTime   @default(now())

  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch          ProductBatch? @relation(fields: [batchId], references: [id])
  recordedByUser User          @relation("LossRecordedBy", fields: [recordedBy], references: [id])

  @@index([shopId, createdAt])
  @@index([productId])
}

// ============================================================================
// 8. AI-ASSISTED PAPER KHATA MIGRATION
// ============================================================================

enum PaperImportBatchStatus {
  PENDING
  PROCESSING
  READY_FOR_REVIEW
  COMMITTED
  CANCELLED
}

enum PaperImportPageStatus {
  PENDING
  EXTRACTED
  FAILED
  REVIEWED
}

model PaperImportBatch {
  id         String                 @id @default(cuid())
  shopId     String
  uploadedBy String
  asOfDate   DateTime               @db.Date
  status     PaperImportBatchStatus @default(PENDING)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  shop           Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  uploadedByUser User              @relation("PaperImportUploadedBy", fields: [uploadedBy], references: [id])
  pages          PaperImportPage[]

  @@index([shopId, status])
}

model PaperImportPage {
  id                 String                @id @default(cuid())
  batchId            String
  imageUrl           String
  status             PaperImportPageStatus @default(PENDING)
  rawExtractedJson   Json?
  confidenceScore    Decimal?              @db.Decimal(4, 3)
  resultingContactId String?
  reviewedBy         String?
  reviewedAt         DateTime?

  batch             PaperImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  resultingContact  Contact?         @relation(fields: [resultingContactId], references: [id])
  reviewedByUser    User?            @relation("PaperImportPageReviewedBy", fields: [reviewedBy], references: [id])
  attachments       Attachment[]

  @@index([batchId, status])
}