# ══════════════════════════════════════════════════════════════
# Hisab Kitab — Monorepo Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Each app (web/server) reads from the root .env via dotenv.

# ─── Shared ───
NODE_ENV=development

# ─── Database (packages/database) ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hisab_kitab?schema=public"

# ─── Backend API (apps/server) ───
SERVER_PORT=4000
CORS_ORIGIN="http://localhost:3000"

# ─── Frontend (apps/web) ───
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# ─── NextAuth ───
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional) ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Firebase Admin SDK ───
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
NEXT_PUBLIC_FCM_VAPID_KEY=""

# ─── Supabase Storage (receipts/attachments) ───
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Gemini API (AI Paper Khata Migration) ───
GEMINI_API_KEY=""

# ─── Cron Security ───
CRON_SECRET="your-cron-secret-here"
