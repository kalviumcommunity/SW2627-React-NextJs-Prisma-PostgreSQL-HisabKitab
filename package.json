{
  "name": "hisab-kitab-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:all": "npm run dev --workspace=apps/web & npm run dev --workspace=apps/server",
    "build": "npm run build --workspace=apps/web",
    "db:push": "npx prisma db push --schema=packages/database/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  }
}
